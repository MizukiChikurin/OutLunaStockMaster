# OutLuna 环境变量配置

# 项目基础配置
OUTLUNA_CACHE_DIR=./data/cache
OUTLUNA_REPORT_DIR=./data/reports
OUTLUNA_DB_PATH=./data/outluna.db
OUTLUNA_CACHE_TTL_HOURS=24

# 数据源配置
OUTLUNA_PREFER_KIMI_DATASOURCE=true
OUTLUNA_KIMI_DATASOURCE_HOME=E:\kimi-datasource
OUTLUNA_AKSHARE_ENABLED=true
OUTLUNA_YFINANCE_ENABLED=true

# LLM 综合研判配置（可选）
OUTLUNA_LLM_PROVIDER=openai
OUTLUNA_LLM_MODEL=gpt-4o
OUTLUNA_LLM_API_KEY=
OUTLUNA_LLM_BASE_URL=

# 回测默认参数
OUTLUNA_DEFAULT_INITIAL_CAPITAL=100000.0
OUTLUNA_DEFAULT_POSITION_LIMIT=5
OUTLUNA_DEFAULT_HOLD_DAYS=5
OUTLUNA_DEFAULT_STOP_LOSS=0.08
OUTLUNA_DEFAULT_TAKE_PROFIT=0.15
